#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

mock=0
if [[ "${1:-}" == "--mock" ]]; then
  mock=1
  shift
fi

port="${MLX_CODEX_PORT:-18000}"
log="${TMPDIR:-/tmp}/mlx-codex-server-smoke.log"
config="${TMPDIR:-/tmp}/mlx-codex-server-smoke-config.json"
rm -f "$log"
rm -f "$config"

args=(--config "$config" --host 127.0.0.1 --port "$port" --model-id 66ton99/gpt-oss-120b)
if [[ "$mock" == 1 ]]; then
  args+=(--mock --adaptation --stream-heartbeat-interval 0.05)
else
  if [[ -z "${MLX_CODEX_MODEL_PATH:-}" ]]; then
    echo "MLX_CODEX_MODEL_PATH is required for non-mock smoke tests" >&2
    exit 1
  fi
  args+=(--model-path "$MLX_CODEX_MODEL_PATH")
fi

python3 -m mlx_codex_server "${args[@]}" >"$log" 2>&1 &
pid=$!
trap 'kill "$pid" 2>/dev/null || true' EXIT

for _ in {1..80}; do
  if curl -fsS "http://127.0.0.1:${port}/health" >/dev/null 2>&1; then
    break
  fi
  sleep 0.25
done

curl -fsS "http://127.0.0.1:${port}/v1/models" | jq .

response="$(curl -fsS "http://127.0.0.1:${port}/v1/responses" \
  -H 'content-type: application/json' \
  -d '{
    "model": "66ton99/gpt-oss-120b",
    "prompt_cache_key": "smoke",
    "input": "Reply only: OK",
    "max_output_tokens": 4,
    "stream": false
  }')"
echo "$response" | jq .
echo "$response" | jq -e '.output[0].content[0].text | length > 0' >/dev/null

tool_response="$(curl -fsS "http://127.0.0.1:${port}/v1/responses" \
  -H 'content-type: application/json' \
  -d '{
    "model": "66ton99/gpt-oss-120b",
    "prompt_cache_key": "smoke-tools",
    "input": [
      {
        "role": "user",
        "content": [{"type": "input_text", "text": "Use this command result."}]
      },
      {
        "type": "function_call_output",
        "call_id": "call_smoke",
        "output": "command output"
      }
    ],
    "max_output_tokens": 4,
    "stream": false
  }')"
echo "$tool_response" | jq .
echo "$tool_response" | jq -e '.output[0].content[0].text | length > 0' >/dev/null

if [[ "$mock" == 1 ]]; then
  patch_response="$(curl -fsS "http://127.0.0.1:${port}/v1/responses" \
    -H 'content-type: application/json' \
    -d '{
      "model": "66ton99/gpt-oss-120b",
      "prompt_cache_key": "smoke-patch",
      "tools": [
        {
          "type": "custom",
          "name": "apply_patch",
          "description": "Apply a patch",
          "format": {"type": "text"}
        }
      ],
      "input": "MOCK_APPLY_PATCH_CALL",
      "max_output_tokens": 32,
      "stream": false
    }')"
  echo "$patch_response" | jq .
  echo "$patch_response" | jq -e '.output[0].type == "custom_tool_call"' >/dev/null
  echo "$patch_response" | jq -e '.output[0].name == "apply_patch"' >/dev/null
  echo "$patch_response" | jq -e '.output[0].input | startswith("*** Begin Patch")' >/dev/null

  patch_stream="$(curl -fsS "http://127.0.0.1:${port}/v1/responses" \
    -H 'content-type: application/json' \
    -d '{
      "model": "66ton99/gpt-oss-120b",
      "prompt_cache_key": "smoke-patch-stream",
      "tools": [
        {
          "type": "custom",
          "name": "apply_patch",
          "description": "Apply a patch",
          "format": {"type": "text"}
        }
      ],
      "input": "MOCK_APPLY_PATCH_CALL",
      "max_output_tokens": 32,
      "stream": true
    }')"
  echo "$patch_stream"
  echo "$patch_stream" | grep -F '"type": "response.output_item.done"' >/dev/null
  echo "$patch_stream" | grep -F '"type": "custom_tool_call"' >/dev/null
  echo "$patch_stream" | grep -F '"name": "apply_patch"' >/dev/null

  heartbeat_stream="$(curl -fsS "http://127.0.0.1:${port}/v1/responses" \
    -H 'content-type: application/json' \
    -d '{
      "model": "66ton99/gpt-oss-120b",
      "prompt_cache_key": "smoke-heartbeat-stream",
      "input": "MOCK_SLOW_STREAM",
      "max_output_tokens": 4,
      "stream": true
    }')"
  echo "$heartbeat_stream"
  echo "$heartbeat_stream" | grep -F ': keep-alive' >/dev/null
  echo "$heartbeat_stream" | grep -F 'progress=' >/dev/null
  echo "$heartbeat_stream" | grep -F '"type": "response.in_progress"' >/dev/null
  echo "$heartbeat_stream" | grep -F 'prompt_tokens=16' >/dev/null
  echo "$heartbeat_stream" | grep -F 'suffix_tokens=16' >/dev/null
  echo "$heartbeat_stream" | grep -F '"type": "response.completed"' >/dev/null

  final_response="$(curl -fsS "http://127.0.0.1:${port}/v1/responses" \
    -H 'content-type: application/json' \
    -d '{
      "model": "66ton99/gpt-oss-120b",
      "prompt_cache_key": "smoke-final-harmony",
      "input": "MOCK_FINAL_HARMONY",
      "max_output_tokens": 32,
      "stream": false
    }')"
  echo "$final_response" | jq .
  echo "$final_response" | jq -e '.output[0].content[0].text == "Clean final answer."' >/dev/null
  echo "$final_response" | jq -e '.output[0].content[0].text | contains("<|channel|>") | not' >/dev/null

  exec_response="$(curl -fsS "http://127.0.0.1:${port}/v1/responses" \
    -H 'content-type: application/json' \
    -d '{
      "model": "66ton99/gpt-oss-120b",
      "prompt_cache_key": "smoke-exec-bracket",
      "input": "MOCK_EXEC_COMMAND_BRACKET",
      "max_output_tokens": 64,
      "stream": false
    }')"
  echo "$exec_response" | jq .
  echo "$exec_response" | jq -e '.output[0].type == "function_call"' >/dev/null
  echo "$exec_response" | jq -e '.output[0].name == "exec_command"' >/dev/null
  echo "$exec_response" | jq -e '.output[0].arguments | fromjson | .cmd == "git add money.js && git commit -m \"Add money.js orchestrator for core money scripts\""' >/dev/null

  latex_response="$(curl -fsS "http://127.0.0.1:${port}/v1/responses" \
    -H 'content-type: application/json' \
    -d '{
      "model": "66ton99/gpt-oss-120b",
      "prompt_cache_key": "smoke-latex-block",
      "input": "MOCK_LATEX_BLOCK",
      "max_output_tokens": 64,
      "stream": false
    }')"
  echo "$latex_response" | jq .
  echo "$latex_response" | jq -e '.output[0].content[0].text | contains("```text")' >/dev/null
  echo "$latex_response" | jq -e '.output[0].content[0].text | contains("[\n  \\\\text") | not' >/dev/null
  echo "$latex_response" | jq -e '.output[0].content[0].text | contains("\\\\text") | not' >/dev/null
  echo "$latex_response" | jq -e '.output[0].content[0].text | contains("\\\\times") | not' >/dev/null

  python3 - <<'PY'
from mlx_codex_server.server import response_input_to_messages
from mlx_codex_server.server import response_text_from_generation
from mlx_codex_server.server import CODEX_ADAPTATION_REMINDER
from mlx_codex_server.server import is_analysis_only_generation
from mlx_codex_server.server import visible_response_text_from_generation
from mlx_codex_server.server import parse_args
from mlx_codex_server.server import tool_arguments_for
from mlx_codex_server.server import tools_for_chat_template
import json
import sys
import tempfile
from pathlib import Path

messages = response_input_to_messages({
    "input": [
        {
            "role": "assistant",
            "content": [{"type": "output_text", "text": "<|channel|>analysis<|message|>hidden<|end|><|start|>assistant<|channel|>final<|message|>visible<|end|>"}],
        }
    ]
}, adaptation=True)
assert messages == [{"role": "assistant", "content": "visible"}], messages

messages = response_input_to_messages({"input": "log contains <|channel|>analysis<|message|>raw<|end|>"}, adaptation=True)
assert "<|channel|>" not in messages[0]["content"], messages
assert "< |channel|>" in messages[0]["content"], messages

messages = response_input_to_messages({"input": "raw <|channel|> tag"}, adaptation=False)
assert "<|channel|>" in messages[0]["content"], messages

visible = response_text_from_generation("<|start|>assistant<|channel|>analysis<|message|>thinking only<|end|>")
assert visible.startswith("[local model produced analysis-only output"), visible
visible = response_text_from_generation("<|channel|>analysis<|message|>thinking only")
assert visible.startswith("[local model produced analysis-only output"), visible
visible = response_text_from_generation("<|channel|>final<|message|>done")
assert visible == "done", visible
visible = response_text_from_generation(
    "<|channel|>analysis<|message|>thinking<|end|>"
    "<|start|>assistant<|channel|>final<|message|>"
    "<|end|><|start|>assistant<|channel|>final<|message|>deterministic"
)
assert visible == "deterministic", visible
visible = response_text_from_generation(
    "<|channel|>analysis<|message|>thinking"
    "<|end|><|start|>assistant<|channel|>final<|message|>"
    "Local model stopped after producing analysis-only output. No tool call was emitted, so no files were changed."
)
assert "No tool call was emitted" in visible, visible
visible = visible_response_text_from_generation(
    "<|channel|>final<|message|>Formula:\n\n"
    "[\n"
    "\\text{cost}(L) = 10^{9} \\times 1.9^{L-1}\n"
    "]\n\n"
    "\\[\n"
    "\\boxed{6.36 \\times 10^{79}}\n"
    "\\]\n\n"
    "$$\\log_{10}(1.9)$$\n\n"
    "[\\boxed{6.36 \\times 10^{79}}]"
)
assert "cost" in visible, visible
assert "```text" in visible, visible
assert "[\n\\text" not in visible, visible
assert "\\[" not in visible, visible
assert "$$" not in visible, visible
assert "[\\boxed" not in visible, visible
assert "\\text" not in visible, visible
assert "\\times" not in visible, visible
assert "\\boxed" not in visible, visible
visible = visible_response_text_from_generation(
    "<|channel|>final<|message|>Formula:\n\n"
    "\\text{cost}(L) = 10^{9} \\times 1.9^{L-1}\n\n"
    "Для L = 255:\n\n"
    "\\begin{aligned}\n"
    "\\text{cost}(255) &= 10^{9} \\times 1.9^{254} \\\\\n"
    "\\log_{10}\\!\\bigl(\\text{cost}(255)\\bigr) &= 9 + 254 \\times \\log_{10}(1.9) \\\\\n"
    "\\end{aligned}\n"
)
assert visible.count("```text") == 2, visible
assert "\\begin{aligned}" not in visible, visible
assert "\\text" not in visible, visible
assert "\\times" not in visible, visible
assert "Formula:\n\n```text" in visible, visible
assert is_analysis_only_generation("<|channel|>analysis<|message|>thinking only"), "analysis-only was not detected"
assert not is_analysis_only_generation("<|channel|>commentary<|message|>I will check files."), "commentary was treated as analysis-only"
assert not is_analysis_only_generation('[tool call (exec_command, ls)]\n{"cmd":"ls"}'), "tool call was treated as analysis-only"

tools = tools_for_chat_template({"tools": [{"type": "custom", "name": "apply_patch", "description": "Apply patch"}]})
assert tools[0]["function"]["name"] == "apply_patch", tools
assert tools[0]["function"]["parameters"]["properties"]["input"]["type"] == "string", tools

arguments = tool_arguments_for("exec_command", "function", '{"cmd":"git add money.js && git commit -m "Add money.js orchestrator for core money scripts""}')
assert arguments == '{"cmd": "git add money.js && git commit -m \\"Add money.js orchestrator for core money scripts\\""}', arguments
assert "avoid LaTeX math delimiters" in CODEX_ADAPTATION_REMINDER, CODEX_ADAPTATION_REMINDER

config = Path(tempfile.gettempdir()) / "mlx-codex-server-parse-args-smoke.json"
config.unlink(missing_ok=True)
sys.argv = ["smoke", "--config", str(config), "--port", "19001", "--adaptation", "--mock"]
args = parse_args()
assert args.port == 19001, args
assert args.adaptation is True, args
assert args.mock is True, args
data = json.loads(config.read_text())
assert data["port"] == 19001, data
assert data["adaptation"] is True, data
assert data["mock"] is False, data
sys.argv = ["smoke", "--config", str(config)]
args = parse_args()
assert args.port == 19001, args
assert args.adaptation is True, args
assert args.mock is False, args
config.unlink(missing_ok=True)
PY
fi

if [[ "$mock" == 1 ]]; then
  python3 - <<PY
import json
from pathlib import Path

config = Path("$config")
assert config.exists(), config
data = json.loads(config.read_text())
assert data.get("adaptation") is True, data
assert data.get("mock") is False, data
PY
fi

echo "smoke test passed"
